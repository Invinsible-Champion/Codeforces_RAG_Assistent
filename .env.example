# Database — Choose one:
#
# Option 1: SQLite (works out of the box, no setup)
DATABASE_URL=sqlite+aiosqlite:///./data/codeforces_rag.db
DATABASE_URL_SYNC=sqlite:///./data/codeforces_rag.db
#
# Option 2: Local PostgreSQL (no Docker needed)
# Make sure PostgreSQL is running and database exists: createdb codeforces_rag
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/codeforces_rag
# DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/codeforces_rag

# OpenAI — Required for embeddings and chat
OPENAI_API_KEY=sk-your-openai-api-key-here

# FAISS
FAISS_INDEX_PATH=./data/faiss_index.bin
FAISS_ID_MAP_PATH=./data/faiss_id_map.json

# App
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
LLM_MODEL=gpt-4o-mini

# Scraping
SCRAPE_DELAY=2.0
MAX_PROBLEMS_PER_INGEST=100
